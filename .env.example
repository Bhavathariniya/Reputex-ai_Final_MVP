# Frontend (Vite) configuration.
# All provider API keys live in backend/.env (server-side) — NOT here.
# The browser only needs to know where the backend is.
VITE_API_BASE_URL=http://localhost:8787

# Public link to the Telegram bot, used by "Scan on Telegram" buttons in the UI.
# Set this to your bot's username (from @BotFather -> /mybots).
VITE_TELEGRAM_BOT_URL=https://t.me/ReputeXAIbot
