# ReputeX backend configuration — copy to `.env` and fill in real values.
# The .env file is gitignored. These keys live ONLY on the server and are
# never shipped to the browser.

# --- Server ---
NODE_ENV=development
PORT=8787
# Comma-separated list of allowed frontend origins (CORS allowlist)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Caching / rate limiting ---
CACHE_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# --- Provider API keys (server-side secrets) ---
# Only these four are used. honeypot.is and Dexscreener need no key.
# Etherscan V2 multichain key (one key works across Ethereum, BSC, Polygon, etc.)
ETHERSCAN_API_KEY=your_etherscan_api_key
# Moralis — holder distribution (free tier)
MORALIS_API_KEY=your_moralis_api_key
# CoinGecko — optional market/community data (free demo tier)
COINGECKO_API_KEY=your_coingecko_api_key
# Gemini — optional AI explanation layer (free tier)
GEMINI_API_KEY=your_gemini_api_key

# --- Telegram bot (optional) ---
# Get the FULL token from @BotFather: format is <bot_id>:<secret>.
# Local dev: run `npm run bot` (long-polling). Production: the API auto-runs the
# bot in webhook mode when this token AND a public URL are set.
TELEGRAM_BOT_TOKEN=
# Public URL of the web app (used for "Full report" buttons).
WEB_APP_URL=http://localhost:8080
# Public https URL of THIS API, used to register the Telegram webhook.
# On Render this is auto-injected as RENDER_EXTERNAL_URL — leave blank there.
PUBLIC_API_URL=
# Optional shared secret for validating inbound webhook calls (auto-derived if blank).
TELEGRAM_WEBHOOK_SECRET=
